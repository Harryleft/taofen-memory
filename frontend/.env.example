# ============================================
# 前端环境变量配置模板
# ============================================
# 使用说明:
# 1. 复制此文件为 .env.local: cp .env.example .env.local
# 2. 填写真实的配置值
# 3. 不要将 .env.local 文件提交到版本控制
# ============================================

# API服务地址
VITE_API_BASE_URL=http://localhost:3001
VITE_API_CACHE_URL=http://localhost:3001

# ============================================
# 数据源配置
# ============================================
# 使用示例数据 (开发/演示)
VITE_USE_SAMPLE_DATA=true

# 使用真实数据 (生产环境)
# VITE_USE_SAMPLE_DATA=false

# ============================================
# IIIF图像服务配置
# ============================================
VITE_IIIF_BASE_URL=https://www.ai4dh.cn/iiif/2
VITE_IIIF_IMAGE_QUALITY=default
VITE_IIIF_MAX_WIDTH=2000
VITE_IIIF_MAX_HEIGHT=2000

# ============================================
# 功能开关
# ============================================
# 启用AI解读功能
VITE_ENABLE_AI_FEATURE=true

# 启用调试模式
VITE_DEBUG=false

# ============================================
# 性能配置
# ============================================
# 图片懒加载
VITE_ENABLE_LAZY_LOADING=true

# 虚拟滚动阈值
VITE_VIRTUAL_SCROLL_THRESHOLD=50

# ============================================
# 第三方服务
# ============================================
# 分析工具 (可选)
# VITE_GA_ID=your_google_analytics_id

# 错误追踪 (可选)
# VITE_SENTRY_DSN=your_sentry_dsn
