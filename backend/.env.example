# ============================================
# 环境变量配置模板
# ============================================
# 使用说明:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填写真实的配置值
# 3. 不要将 .env 文件提交到版本控制
# ============================================

# 服务配置
NODE_ENV=development
PORT=3001

# ============================================
# AI服务配置 (智谱AI GLM-4.5)
# ============================================
# 获取API Key: https://open.bigmodel.cn/
AI_API_KEY=your_ai_api_key_here
AI_API_BASE=https://open.bigmodel.cn/api/paas/v4/
AI_MODEL=glm-4.5

# ============================================
# Redis缓存配置
# ============================================
# 开发环境
REDIS_URL=redis://:dev_redis_password_2024@localhost:6379

# 生产环境示例
# REDIS_URL=redis://:your_password@redis-server:6379

# ============================================
# IIIF图像服务配置
# ============================================
# IIIF服务地址
IIIF_BASE_URL=https://www.ai4dh.cn/iiif/2
IIIF_AUTH_USERNAME=your_username
IIIF_AUTH_PASSWORD=your_password

# 本地IIIF服务 (开发环境)
# IIIF_BASE_URL=http://localhost:8282/iiif/2

# ============================================
# 数据源配置
# ============================================
# 使用示例数据 (开发/演示)
USE_SAMPLE_DATA=true

# 使用真实数据 (生产环境)
# USE_SAMPLE_DATA=false
# DATA_PATH=/path/to/real/data

# ============================================
# CORS配置
# ============================================
# 允许的前端域名
CORS_ORIGIN=http://localhost:5173

# 生产环境
# CORS_ORIGIN=https://your-domain.com

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# 性能配置
# ============================================
# 缓存时间 (秒)
CACHE_TTL_IIIF_INFO=86400      # 24小时
CACHE_TTL_IIIF_IMAGE=7200      # 2小时
CACHE_TTL_GENERAL=3600         # 1小时

# ============================================
# 安全配置
# ============================================
# JWT密钥 (如果使用认证)
JWT_SECRET=your_jwt_secret_here

# API限流配置
RATE_LIMIT_WINDOW_MS=900000    # 15分钟
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# 开发工具
# ============================================
# 启用调试模式
DEBUG=false

# 启用性能监控
ENABLE_PERFORMANCE_MONITORING=true

# ============================================
# 其他配置
# ============================================
# 时区
TZ=Asia/Shanghai

# 语言
LANGUAGE=zh-CN
